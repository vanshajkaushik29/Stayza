<% layout("/layouts/boilerplate") %>   <!-- <%= success %>  -->

<!-- Simple Hero Text -->
<div class="hero-text">
    <h1>Find Your Perfect Stay</h1>
    <p>Discover amazing places across India</p>
</div>

<div class="features-section">
    <h2>Why Stay With Us</h2>
    <div class="features-grid">
        <div class="feature">
<div class="feature-icon">📋</div>
<h3>Easy Hosting</h3>
<p>List your property in minutes</p>
        </div>
        <div class="feature">
            <div class="feature-icon">💰</div>
            <h3>Best Price Guarantee</h3>
            <p>We match any lower price</p>
        </div>
        <div class="feature">
            <div class="feature-icon">⭐</div>
            <h3>Verified Properties</h3>
            <p>All stays are quality checked</p>
        </div>
        <div class="feature">
            <div class="feature-icon">🏠</div>
            <h3>100+ Listings</h3>
            <p>Across 20+ cities in India</p>
        </div>
    </div>
</div>

<!-- Added spacing before All Listings -->
<div style="margin-top: 3rem;"></div>

<h1>All Listings</h1>

<!-- <form action="/listings/new" method="GET">
    <button>Create New Listing</button>
</form> -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
    <% for(let listing of allListings){ %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card col listing-card">
                <img src="<%=listing.image.url%>" class="card-img-top" alt="img" style="height:20rem">
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %> </b>  <br>
                        &#8377;<%= listing.price.toLocaleString("en-IN") %>
                    </p>
                </div>
            </div>
        </a>
    <% } %>
</div>